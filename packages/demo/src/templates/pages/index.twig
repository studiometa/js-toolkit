      {% include '@ui/Figure/Figure.twig' with {
        src: 'https://picsum.photos/seed/index/400/400',
        width: 400,
        height: 400,
        attr: {
          class: 'max-w-sm',
          data_option_debug: true,
          data_option_enter_from: 'scale-90 opacity-0',
          data_option_enter_active: 'transition delay-100'
        },
        img_attr: {
          class: 'scale-90 opacity-0'
        }
      } %}
